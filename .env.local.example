# ============================================================
# Sassoferrato Scienza — variabili d'ambiente
# Copia in .env.local e compila con le chiavi reali.
# ============================================================

# --- Supabase (progetto Fosforo riusato; tabelle prefissate sass_) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-fosforo-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (email di conferma con QR) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Mittente: dominio verificato su Resend (fosforoscienza.it è verificato)
RESEND_FROM=Sassoferrato Scienza <noreply@fosforoscienza.it>
RESEND_REPLY_TO=info@fosforoscienza.it

# --- URL pubblico del sito (usato nei QR e nei link email) ---
NEXT_PUBLIC_SITE_URL=https://sassoferratoscienza.org

# --- Rate limit (opzionale: Upstash Redis). Se assenti, l'app funziona
#     senza protezione rate-limit (degradazione graceful). ---
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx
